{
  "format": "glyph-knowledge-pack",
  "version": 1,
  "id": "floke-heuristics-v1",
  "description": "Built-in path and title heuristics — no API keys, ships with Senza.",
  "artistAliases": [
    { "match": "va", "artist": "Various Artists" },
    { "match": "various", "artist": "Various Artists" }
  ],
  "titleCleanup": [
    { "pattern": "\\s*\\(feat\\.[^)]+\\)", "replace": "" },
    { "pattern": "\\s*\\(ft\\.[^)]+\\)", "replace": "" },
    { "pattern": "\\s*\\[feat\\.[^\\]]+\\]", "replace": "" }
  ],
  "folderRules": [
    { "match": "soundtrack", "genre": "Soundtrack" },
    { "match": "ost", "genre": "Soundtrack" },
    { "match": "саундтрек", "genre": "Soundtrack" }
  ],
  "examples": []
}
